#!/bin/sh /etc/rc.common
# shellcheck disable=SC2034  # USE_PROCD, START, STOP used by rc.common
# shellcheck disable=SC2039  # procd_* functions defined by rc.common
USE_PROCD=1
START=19
STOP=81

MODULES_DIR=/etc/norypt
CONFIG=norypt

_cfg() { uci -q get "${CONFIG}.settings.$1" 2>/dev/null || echo "0"; }

start_service() {
  _cfg_enabled=$(_cfg enabled)
  [ "${_cfg_enabled}" = "1" ] || return 0
  _cfg_on_boot=$(_cfg on_boot)
  [ "${_cfg_on_boot}" = "1" ] || return 0

  procd_open_instance
  procd_set_param command /bin/bash "${MODULES_DIR}/run.sh" --boot
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_set_param respawn 0
  procd_close_instance
}

run() { /bin/bash "${MODULES_DIR}/run.sh" --boot; }
